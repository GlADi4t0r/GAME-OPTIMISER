<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#09080C"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BGMI Optimizer"
        android:textColor="#E2E1E6"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.03"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="30dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hardware Uncap &amp; Safe RAM Monitor"
        android:textColor="#5C5A66"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="4dp" />

    <LinearLayout
        android:id="@+id/statusBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#13111C"
        android:padding="20dp"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ENGINE STATE"
            android:textColor="#423F52"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• Refresh Rate: 120Hz Glitch Mode\n• Memory Filter: System-Safe Active"
            android:textColor="#B9B7C2"
            android:textSize="15sp"
            android:layout_marginTop="10dp"
            android:lineSpacingMultiplier="1.3" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnLockHardware"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="1. Uncap 120Hz &amp; Max Gyro"
            android:textColor="#D4D2DB"
            android:textStyle="bold"
            android:backgroundTint="#231F33"
            android:layout_marginBottom="12dp"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnCameraLatch"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="2. Apply Settings (Camera)"
            android:textColor="#A6A3B0"
            android:textStyle="bold"
            android:backgroundTint="#191821"
            android:layout_marginBottom="12dp"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnStartWatchdog"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:text="3. Start Clean Engine &amp; Play"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#3E2D54"
            android:layout_marginBottom="24dp"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnStopAll"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="Shut Down &amp; Restore Normal"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#421B24"
            android:textAllCaps="false" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>